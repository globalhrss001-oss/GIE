---
import { company } from '../data/company';
import { mainNavigation } from '../data/navigation';
import { asset, url } from '../utils/url';

const currentPath = Astro.url.pathname;
const menuItems = mainNavigation.filter((item) => item.columns);

function normalizePath(path: string): string {
  const base = import.meta.env.BASE_URL;
  if (base !== '/' && path.startsWith(base)) {
    return path.slice(base.length - 1) || '/';
  }
  return path;
}

const normalizedCurrent = normalizePath(currentPath);

function isHomeActive(): boolean {
  return (
    normalizedCurrent === '/' ||
    normalizedCurrent === '' ||
    currentPath === url('/') ||
    currentPath.endsWith('/GIE') ||
    currentPath.endsWith('/GIE/')
  );
}

function isNavItemActive(item: (typeof mainNavigation)[number]): boolean {
  if (item.href === '/') {
    return isHomeActive();
  }
  return item.matchPaths?.some((segment) => normalizedCurrent.includes(segment)) ?? false;
}

function isLinkActive(href: string): boolean {
  const [pathPart] = href.split('#');
  if (pathPart === '/') {
    return isHomeActive();
  }
  return normalizedCurrent.includes(pathPart);
}
---

<header id="site-header" class="relative sticky top-0 z-50 border-b border-gray-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2 sm:px-6 sm:py-3">
    <a href={url('/')} class="flex items-center gap-3 sm:gap-4">
      <img
        src={asset('images/logo/gie-logo.png')}
        alt={company.logoAlt}
        class="h-16 w-auto max-w-[200px] object-contain sm:h-[72px] sm:max-w-[240px] lg:h-20 lg:max-w-[280px]"
        width="280"
        height="80"
      />
      <span class="hidden leading-tight sm:block">
        <span class="block text-sm font-semibold tracking-wider text-gie-navy uppercase lg:text-base">
          Global
        </span>
        <span class="block text-sm font-semibold tracking-wider text-gie-navy uppercase lg:text-base">
          Infrastructure
        </span>
        <span class="block text-sm font-semibold tracking-wider text-gie-navy uppercase lg:text-base">
          Engineering
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {
        mainNavigation.map((item) => {
          const active = isNavItemActive(item);

          if (!item.columns) {
            return (
              <a
                href={url(item.href!)}
                class:list={[
                  'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                  active ? 'text-gie-navy' : 'text-gie-text hover:text-gie-navy',
                ]}
              >
                {item.label}
              </a>
            );
          }

          return (
            <div class="nav-dropdown-trigger" data-menu={item.id}>
              <a
                href={url(item.href!)}
                class:list={[
                  'flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium transition-colors',
                  active ? 'text-gie-navy' : 'text-gie-text hover:text-gie-navy',
                ]}
                aria-haspopup="true"
              >
                {item.label}
                <svg class="nav-chevron h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
            </div>
          );
        })
      }
    </nav>

    <button
      type="button"
      id="mobile-menu-btn"
      class="inline-flex items-center justify-center rounded-md p-2 text-gie-navy hover:bg-gie-gray lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mega-menu" class="mega-menu absolute right-0 left-0 top-full z-40 hidden border-t border-gray-200 bg-white shadow-lg" aria-hidden="true">
    {
      menuItems.map((item) => (
        <div class="mega-panel hidden" data-panel={item.id}>
          <div class="mx-auto grid max-w-6xl grid-cols-2 gap-12 px-6 py-8 sm:px-8">
            {
              item.columns?.map((column, colIndex) => (
                <div class:list={[colIndex === 1 && 'border-l border-gray-200 pl-12']}>
                  <p class="text-xs font-semibold tracking-wider text-gie-navy-light uppercase">
                    {column.heading}
                  </p>
                  <ul class="mt-4 space-y-2.5">
                    {
                      column.links.map((link) => (
                        <li>
                          <a
                            href={url(link.href)}
                            class:list={[
                              'text-sm hover:text-gie-navy',
                              isLinkActive(link.href)
                                ? 'font-medium text-gie-navy'
                                : 'text-gie-text',
                            ]}
                          >
                            {link.label}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </div>
              ))
            }
          </div>
        </div>
      ))
    }
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white lg:hidden"
    aria-label="Mobile navigation"
  >
    <div class="mx-auto max-w-6xl px-4 py-3 sm:px-6">
      {
        mainNavigation.map((item) => {
          if (!item.columns) {
            return (
              <a
                href={url(item.href!)}
                class:list={[
                  'block rounded-md px-3 py-3 text-sm font-medium',
                  isNavItemActive(item)
                    ? 'text-gie-navy'
                    : 'text-gie-text hover:bg-gie-gray hover:text-gie-navy',
                ]}
              >
                {item.label}
              </a>
            );
          }

          return (
            <details class="group/mobile border-b border-gray-100 py-1 last:border-0">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-3 text-sm font-medium text-gie-text marker:content-none hover:bg-gie-gray hover:text-gie-navy [&::-webkit-details-marker]:hidden">
                <span>{item.label}</span>
                <svg
                  class="h-4 w-4 shrink-0 transition-transform group-open/mobile:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="space-y-4 pb-3 pl-3">
                <a
                  href={url(item.href!)}
                  class="block rounded-md px-3 py-2 text-sm font-medium text-gie-navy hover:bg-gie-gray"
                >
                  View {item.label} page
                </a>
                {
                  item.columns?.map((column) => (
                    <div>
                      <p class="px-3 text-xs font-semibold tracking-wider text-gie-navy-light uppercase">
                        {column.heading}
                      </p>
                      <ul class="mt-2 space-y-1">
                        {
                          column.links.map((link) => (
                            <li>
                              <a
                                href={url(link.href)}
                                class="block rounded-md px-3 py-2 text-sm text-gie-text hover:bg-gie-gray hover:text-gie-navy"
                              >
                                {link.label}
                              </a>
                            </li>
                          ))
                        }
                      </ul>
                    </div>
                  ))
                }
              </div>
            </details>
          );
        })
      }
    </div>
  </nav>
</header>

<style>
  .mega-menu::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 0.75rem;
  }

  .nav-dropdown-trigger:hover .nav-chevron,
  .nav-dropdown-trigger:focus-within .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-chevron {
    transition: transform 0.15s ease;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const megaMenu = document.getElementById('mega-menu');
  const triggers = header?.querySelectorAll('.nav-dropdown-trigger');
  const panels = megaMenu?.querySelectorAll('.mega-panel');
  let hideTimer: ReturnType<typeof setTimeout> | undefined;

  function showPanel(id: string) {
    if (!megaMenu || !panels) return;
    clearTimeout(hideTimer);
    megaMenu.classList.remove('hidden');
    megaMenu.setAttribute('aria-hidden', 'false');
    panels.forEach((panel) => {
      panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== id);
    });
  }

  function hideMenu() {
    hideTimer = setTimeout(() => {
      megaMenu?.classList.add('hidden');
      megaMenu?.setAttribute('aria-hidden', 'true');
      panels?.forEach((panel) => panel.classList.add('hidden'));
    }, 100);
  }

  triggers?.forEach((trigger) => {
    const id = trigger.getAttribute('data-menu');
    if (!id) return;

    trigger.addEventListener('mouseenter', () => showPanel(id));
    trigger.addEventListener('focusin', () => showPanel(id));
  });

  header?.addEventListener('mouseleave', hideMenu);

  megaMenu?.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  megaMenu?.addEventListener('mouseleave', hideMenu);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      clearTimeout(hideTimer);
      megaMenu?.classList.add('hidden');
      megaMenu?.setAttribute('aria-hidden', 'true');
      panels?.forEach((panel) => panel.classList.add('hidden'));
    }
  });

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
</script>
