---
import OrgChartModal from './OrgChartModal.astro';
import { company } from '../data/company';
import { mainNavigation, type NavLinkItem } from '../data/navigation';
import { asset, url } from '../utils/url';

const currentPath = Astro.url.pathname;

function normalizePath(path: string): string {
  const base = import.meta.env.BASE_URL;
  if (base !== '/' && path.startsWith(base)) {
    return path.slice(base.length - 1) || '/';
  }
  return path;
}

const normalizedCurrent = normalizePath(currentPath);

function isHomeActive(): boolean {
  return (
    normalizedCurrent === '/' ||
    normalizedCurrent === '' ||
    currentPath === url('/') ||
    currentPath.endsWith('/GIE') ||
    currentPath.endsWith('/GIE/')
  );
}

function isNavItemActive(item: (typeof mainNavigation)[number]): boolean {
  if (item.href === '/') {
    return isHomeActive();
  }
  return item.matchPaths?.some((segment) => normalizedCurrent.includes(segment)) ?? false;
}

function isLinkActive(href: string): boolean {
  const [pathPart, hashPart] = href.split('#');
  const normalizedHref = pathPart === '/' ? pathPart : pathPart.replace(/\/$/, '');
  const normalizedPath =
    normalizedCurrent === '' || normalizedCurrent === '/'
      ? '/'
      : normalizedCurrent.replace(/\/$/, '');

  if (pathPart === '/') {
    return isHomeActive() && !hashPart;
  }

  const pathMatches =
    normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);

  if (!hashPart) {
    return pathMatches;
  }

  return pathMatches && Astro.url.hash === `#${hashPart}`;
}

const navLinkBase =
  'relative inline-flex items-center gap-1.5 px-3.5 py-2 text-sm font-medium transition-colors duration-200';

const navLinkIdle = 'text-gie-text hover:text-gie-navy';

const navLinkActive = 'text-gie-navy';

const dropdownItemBase =
  'group/item mx-1.5 flex w-full items-start gap-2.5 rounded-md px-3 py-2.5 text-left text-sm leading-snug transition-colors text-gie-text hover:bg-gie-gray hover:text-gie-navy';

const mobileDropdownItemBase =
  'block w-full px-4 py-2.5 text-left text-sm transition-colors text-gie-text hover:bg-white hover:text-gie-navy';

function isOrgChartLink(link: NavLinkItem): boolean {
  return link.action === 'org-chart';
}
---

<header id="site-header" class="relative sticky top-0 z-50 overflow-visible border-b border-gray-200/80 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-0.5 sm:px-6 sm:py-1">
    <a href={url('/')} class="brand-lockup -my-1 flex shrink-0 items-center sm:-my-1.5">
      <img
        src={asset('images/logo/gie-logo.png')}
        alt={company.logoAlt}
        class="brand-lockup__logo h-24 w-24 shrink-0 object-contain sm:h-28 sm:w-28 lg:h-32 lg:w-32"
        width="128"
        height="128"
      />
      <span class="brand-lockup__text hidden leading-none sm:block">
        <span class="block text-xs font-semibold tracking-wide text-gie-navy uppercase lg:text-sm">
          Global
        </span>
        <span class="block text-xs font-semibold tracking-wide text-gie-navy uppercase lg:text-sm">
          Infrastructure
        </span>
        <span class="block text-xs font-semibold tracking-wide text-gie-navy uppercase lg:text-sm">
          Engineering
        </span>
      </span>
    </a>

    <nav class="nav-desktop hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {
        mainNavigation.map((item) => {
          const active = isNavItemActive(item);

          if (!item.dropdownLinks) {
            return (
              <a
                href={url(item.href!)}
                class:list={[navLinkBase, active ? navLinkActive : navLinkIdle]}
              >
                {item.label}
                {
                  active && (
                    <span
                      class="absolute inset-x-2 bottom-0 h-0.5 rounded-full bg-gie-navy"
                      aria-hidden="true"
                    />
                  )
                }
              </a>
            );
          }

          const hasFooter = item.dropdownLinks.at(-1)?.label.toLowerCase().startsWith('view all');
          const panelLinks = hasFooter ? item.dropdownLinks.slice(0, -1) : item.dropdownLinks;
          const footerLink = hasFooter ? item.dropdownLinks.at(-1) : null;

          return (
            <div
              class:list={['nav-dropdown-trigger relative', active && 'is-active']}
              data-menu={item.id}
            >
              <a
                href={url(item.href!)}
                class:list={[
                  navLinkBase,
                  'nav-dropdown-link',
                  active ? navLinkActive : navLinkIdle,
                ]}
                aria-haspopup="true"
              >
                {item.label}
                {
                  active && (
                    <span
                      class="absolute inset-x-2 bottom-0 h-0.5 rounded-full bg-gie-navy"
                      aria-hidden="true"
                    />
                  )
                }
                <svg
                  class="nav-chevron h-4 w-4 shrink-0 text-gie-muted transition-transform duration-200"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </a>

              <div class="nav-dropdown-panel pointer-events-none absolute top-[calc(100%+0.35rem)] left-0 z-50 w-[19rem] opacity-0 transition-all duration-200" role="menu">
                <div class="overflow-hidden rounded-xl border border-gray-200/90 bg-white shadow-[0_16px_40px_-12px_rgba(43,58,120,0.25)] ring-1 ring-black/5">
                  <div class="border-b border-gie-navy/10 bg-gradient-to-r from-gie-navy to-gie-navy-light px-4 py-3">
                    <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-white/75">
                      Browse
                    </p>
                    <p class="mt-0.5 text-sm font-semibold text-white">{item.label}</p>
                  </div>

                  <ul class="nav-dropdown-list max-h-[17rem] overflow-y-auto py-1.5">
                    {
                      panelLinks.map((link) => (
                        <li role="none">
                          {isOrgChartLink(link) ? (
                            <button
                              type="button"
                              role="menuitem"
                              data-org-chart-open
                              class={dropdownItemBase}
                            >
                              <span
                                class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gray-300 transition-colors group-hover/item:bg-gie-navy"
                                aria-hidden="true"
                              />
                              <span>{link.label}</span>
                            </button>
                          ) : (
                            <a
                              href={url(link.href!)}
                              role="menuitem"
                              class:list={[
                                dropdownItemBase,
                                isLinkActive(link.href!)
                                  ? 'bg-gie-navy/8 font-medium text-gie-navy'
                                  : '',
                              ]}
                            >
                              <span
                                class:list={[
                                  'mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full transition-colors',
                                  isLinkActive(link.href!)
                                    ? 'bg-gie-navy'
                                    : 'bg-gray-300 group-hover/item:bg-gie-navy',
                                ]}
                                aria-hidden="true"
                              />
                              <span>{link.label}</span>
                            </a>
                          )}
                        </li>
                      ))
                    }
                  </ul>

                  {
                    footerLink && (
                      <div class="border-t border-gray-100 bg-gie-gray/50 px-3 py-2.5">
                        <a
                          href={url(footerLink.href)}
                          role="menuitem"
                          class:list={[
                            'flex items-center justify-between rounded-md px-3 py-2 text-sm font-semibold transition-colors',
                            isLinkActive(footerLink.href)
                              ? 'text-gie-navy'
                              : 'text-gie-navy-light hover:text-gie-navy',
                          ]}
                        >
                          {footerLink.label}
                          <span aria-hidden="true">→</span>
                        </a>
                      </div>
                    )
                  }
                </div>
              </div>
            </div>
          );
        })
      }
    </nav>

    <button
      type="button"
      id="mobile-menu-btn"
      class="inline-flex items-center justify-center rounded-md p-2 text-gie-navy hover:bg-gie-gray lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white lg:hidden"
    aria-label="Mobile navigation"
  >
    <div class="mx-auto max-w-6xl px-4 py-3 sm:px-6">
      {
        mainNavigation.map((item) => {
          if (!item.dropdownLinks) {
            return (
              <a
                href={url(item.href!)}
                class:list={[
                  'block rounded-md px-3 py-3 text-sm font-medium',
                  isNavItemActive(item)
                    ? 'bg-gie-navy/8 text-gie-navy'
                    : 'text-gie-text hover:bg-gie-gray hover:text-gie-navy',
                ]}
              >
                {item.label}
              </a>
            );
          }

          const hasFooter = item.dropdownLinks.at(-1)?.label.toLowerCase().startsWith('view all');
          const panelLinks = hasFooter ? item.dropdownLinks.slice(0, -1) : item.dropdownLinks;
          const footerLink = hasFooter ? item.dropdownLinks.at(-1) : null;

          return (
            <details class="group/mobile py-1">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-3 text-sm font-medium text-gie-text marker:content-none hover:bg-gie-gray hover:text-gie-navy [&::-webkit-details-marker]:hidden">
                <span>{item.label}</span>
                <svg
                  class="h-4 w-4 shrink-0 text-gie-muted transition-transform group-open/mobile:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="mt-1 overflow-hidden rounded-lg border border-gray-200 bg-gie-gray/30">
                <ul class="py-1">
                  {
                    panelLinks.map((link) => (
                      <li>
                        {isOrgChartLink(link) ? (
                          <button
                            type="button"
                            data-org-chart-open
                            class={mobileDropdownItemBase}
                          >
                            {link.label}
                          </button>
                        ) : (
                          <a
                            href={url(link.href!)}
                            class:list={[
                              'block px-4 py-2.5 text-sm transition-colors',
                              isLinkActive(link.href!)
                                ? 'bg-white font-medium text-gie-navy'
                                : 'text-gie-text hover:bg-white hover:text-gie-navy',
                            ]}
                          >
                            {link.label}
                          </a>
                        )}
                      </li>
                    ))
                  }
                </ul>
                {
                  footerLink && (
                    <div class="border-t border-gray-200 bg-white px-4 py-2.5">
                      <a href={url(footerLink.href)} class="text-sm font-semibold text-gie-navy-light">
                        {footerLink.label} →
                      </a>
                    </div>
                  )
                }
              </div>
            </details>
          );
        })
      }
    </div>
  </nav>
</header>

<OrgChartModal />

<style>
  .brand-lockup {
    gap: 0.125rem;
  }

  .brand-lockup__logo {
    margin-right: -0.35rem;
  }

  .brand-lockup__text {
    margin-left: -0.15rem;
  }

  @media (min-width: 1024px) {
    .brand-lockup__logo {
      margin-right: -0.5rem;
    }
  }

  .nav-dropdown-panel::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 0.5rem;
  }

  .nav-dropdown-trigger:hover .nav-chevron,
  .nav-dropdown-trigger:focus-within .nav-chevron {
    transform: rotate(180deg);
    color: var(--color-gie-navy);
  }

  .nav-dropdown-trigger:hover .nav-dropdown-panel,
  .nav-dropdown-trigger:focus-within .nav-dropdown-panel {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }

  .nav-chevron {
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .nav-dropdown-list {
    scrollbar-width: thin;
    scrollbar-color: #cbd5e1 transparent;
  }

  .nav-dropdown-list::-webkit-scrollbar {
    width: 6px;
  }

  .nav-dropdown-list::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 9999px;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
</script>
