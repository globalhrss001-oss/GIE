---
import { company } from '../data/company';
import { mainNavigation } from '../data/navigation';
import { asset, url } from '../utils/url';

const currentPath = Astro.url.pathname;

function normalizePath(path: string): string {
  const base = import.meta.env.BASE_URL;
  if (base !== '/' && path.startsWith(base)) {
    return path.slice(base.length - 1) || '/';
  }
  return path;
}

const normalizedCurrent = normalizePath(currentPath);

function isHomeActive(): boolean {
  return (
    normalizedCurrent === '/' ||
    normalizedCurrent === '' ||
    currentPath === url('/') ||
    currentPath.endsWith('/GIE') ||
    currentPath.endsWith('/GIE/')
  );
}

function isNavItemActive(item: (typeof mainNavigation)[number]): boolean {
  if (item.href === '/') {
    return isHomeActive();
  }
  return item.matchPaths?.some((segment) => normalizedCurrent.includes(segment)) ?? false;
}

function isLinkActive(href: string): boolean {
  const [pathPart, hashPart] = href.split('#');
  const normalizedHref = pathPart === '/' ? pathPart : pathPart.replace(/\/$/, '');
  const normalizedPath =
    normalizedCurrent === '' || normalizedCurrent === '/'
      ? '/'
      : normalizedCurrent.replace(/\/$/, '');

  if (pathPart === '/') {
    return isHomeActive() && !hashPart;
  }

  const pathMatches =
    normalizedPath === normalizedHref || normalizedPath.startsWith(`${normalizedHref}/`);

  if (!hashPart) {
    return pathMatches;
  }

  return pathMatches && Astro.url.hash === `#${hashPart}`;
}
---

<header id="site-header" class="relative sticky top-0 z-50 overflow-visible border-b border-gray-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-0.5 sm:px-6 sm:py-1">
    <a href={url('/')} class="-my-1 flex items-center gap-2 sm:-my-1.5 sm:gap-3">
      <img
        src={asset('images/logo/gie-logo.png')}
        alt={company.logoAlt}
        class="h-24 w-24 shrink-0 object-contain sm:h-28 sm:w-28 lg:h-32 lg:w-32"
        width="128"
        height="128"
      />
      <span class="hidden leading-none sm:block">
        <span class="block text-xs font-semibold tracking-wider text-gie-navy uppercase lg:text-sm">
          Global
        </span>
        <span class="block text-xs font-semibold tracking-wider text-gie-navy uppercase lg:text-sm">
          Infrastructure
        </span>
        <span class="block text-xs font-semibold tracking-wider text-gie-navy uppercase lg:text-sm">
          Engineering
        </span>
      </span>
    </a>

    <nav class="hidden items-stretch gap-0.5 lg:flex" aria-label="Main navigation">
      {
        mainNavigation.map((item) => {
          const active = isNavItemActive(item);

          if (!item.dropdownLinks) {
            return (
              <a
                href={url(item.href!)}
                class:list={[
                  'flex items-center px-3 py-2.5 text-sm font-semibold tracking-wide uppercase transition-colors',
                  active
                    ? 'bg-gie-navy text-white'
                    : 'text-gie-text hover:bg-gie-navy hover:text-white',
                ]}
              >
                {item.label}
              </a>
            );
          }

          return (
            <div
              class:list={[
                'nav-dropdown-trigger group relative',
                active && 'is-active',
              ]}
              data-menu={item.id}
            >
              <a
                href={url(item.href!)}
                class:list={[
                  'flex items-center gap-1.5 px-3 py-2.5 text-sm font-semibold tracking-wide uppercase transition-colors',
                  active
                    ? 'bg-gie-navy text-white'
                    : 'text-gie-text group-hover:bg-gie-navy group-hover:text-white group-focus-within:bg-gie-navy group-focus-within:text-white',
                ]}
                aria-haspopup="true"
              >
                {item.label}
                <svg
                  class="nav-chevron h-3.5 w-3.5 shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M5.25 7.5 10 12.25 14.75 7.5H5.25Z" />
                </svg>
              </a>

              <div
                class="nav-dropdown-panel pointer-events-none absolute top-full left-0 z-50 min-w-[17rem] max-w-[20rem] -translate-y-1 opacity-0 transition-all duration-150 group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100"
                role="menu"
              >
                <ul class="max-h-80 overflow-y-auto border border-gray-200 bg-white shadow-lg">
                  {
                    item.dropdownLinks.map((link, index) => (
                      <li role="none">
                        <a
                          href={url(link.href)}
                          role="menuitem"
                          class:list={[
                            'block border-b border-dotted border-gray-300 px-4 py-2.5 text-sm transition-colors hover:bg-gie-gray',
                            index === item.dropdownLinks!.length - 1 && 'border-b-0 font-semibold text-gie-navy',
                            isLinkActive(link.href)
                              ? 'bg-gie-gray/70 font-medium text-gie-navy'
                              : 'text-gie-text hover:text-gie-navy',
                          ]}
                        >
                          {link.label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          );
        })
      }
    </nav>

    <button
      type="button"
      id="mobile-menu-btn"
      class="inline-flex items-center justify-center rounded-md p-2 text-gie-navy hover:bg-gie-gray lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white lg:hidden"
    aria-label="Mobile navigation"
  >
    <div class="mx-auto max-w-6xl px-4 py-3 sm:px-6">
      {
        mainNavigation.map((item) => {
          if (!item.dropdownLinks) {
            return (
              <a
                href={url(item.href!)}
                class:list={[
                  'block border-b border-dotted border-gray-200 px-3 py-3 text-sm font-semibold uppercase tracking-wide',
                  isNavItemActive(item)
                    ? 'text-gie-navy'
                    : 'text-gie-text hover:bg-gie-gray hover:text-gie-navy',
                ]}
              >
                {item.label}
              </a>
            );
          }

          return (
            <details class="group/mobile border-b border-dotted border-gray-200 py-1">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-3 py-3 text-sm font-semibold uppercase tracking-wide text-gie-text marker:content-none hover:bg-gie-gray hover:text-gie-navy [&::-webkit-details-marker]:hidden">
                <span>{item.label}</span>
                <svg
                  class="h-3.5 w-3.5 shrink-0 transition-transform group-open/mobile:rotate-180"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M5.25 7.5 10 12.25 14.75 7.5H5.25Z" />
                </svg>
              </summary>
              <ul class="pb-2">
                {
                  item.dropdownLinks.map((link, index) => (
                    <li>
                      <a
                        href={url(link.href)}
                        class:list={[
                          'block border-b border-dotted border-gray-200 px-5 py-2.5 text-sm hover:bg-gie-gray hover:text-gie-navy',
                          index === item.dropdownLinks!.length - 1 && 'border-b-0 font-semibold text-gie-navy',
                          isLinkActive(link.href) ? 'text-gie-navy' : 'text-gie-text',
                        ]}
                      >
                        {link.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </details>
          );
        })
      }
    </div>
  </nav>
</header>

<style>
  .nav-dropdown-panel::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 0.5rem;
  }

  .nav-dropdown-trigger:hover .nav-chevron,
  .nav-dropdown-trigger:focus-within .nav-chevron,
  .nav-dropdown-trigger.is-active .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-chevron {
    transition: transform 0.15s ease;
  }

  .nav-dropdown-panel ul {
    scrollbar-width: thin;
    scrollbar-color: #9ca3af #f3f4f6;
  }

  .nav-dropdown-panel ul::-webkit-scrollbar {
    width: 8px;
  }

  .nav-dropdown-panel ul::-webkit-scrollbar-track {
    background: #f3f4f6;
  }

  .nav-dropdown-panel ul::-webkit-scrollbar-thumb {
    background: #9ca3af;
    border-radius: 9999px;
  }

  .nav-dropdown-panel ul::-webkit-scrollbar-button {
    display: block;
    height: 8px;
    background: #f3f4f6;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
</script>
