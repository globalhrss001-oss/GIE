---
import { company, navLinks } from '../data/company';
import { primaryOffice } from '../data/offices';
import { url } from '../utils/url';
import LogoMark from './LogoMark.astro';

const quickLinkMidpoint = Math.ceil(navLinks.length / 2);
const quickLinkColumns = [navLinks.slice(0, quickLinkMidpoint), navLinks.slice(quickLinkMidpoint)];
---

<footer class="border-t border-gray-200 bg-gie-navy text-white">
  <div class="mx-auto grid max-w-6xl gap-6 px-4 py-6 sm:px-6 md:grid-cols-3 md:gap-4">
    <div>
      <LogoMark size="sm" onDark />
      <p class="mt-3 text-xs font-bold tracking-wider uppercase">Global Infrastructure Engineering</p>
      <p class="mt-1 text-xs leading-relaxed text-gray-300">{company.tagline}</p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Quick Links</p>
      <div class="mt-2 grid grid-cols-2 gap-x-6 gap-y-1">
        {
          quickLinkColumns.map((column) => (
            <ul class="space-y-1">
              {
                column.map((link) => (
                  <li>
                    <a href={url(link.href)} class="text-xs text-gray-200 hover:text-white">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          ))
        }
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Singapore Office</p>
      <address class="mt-2 space-y-0.5 text-xs not-italic leading-relaxed text-gray-200">
        <span class="block">{primaryOffice.address?.join(', ')}</span>
        <span class="block">
          Tel: <a href={`tel:${primaryOffice.phone}`} class="hover:text-white">{primaryOffice.phone}</a>
          {' · '}
          <a href={`mailto:${primaryOffice.email}`} class="hover:text-white">{primaryOffice.email}</a>
        </span>
      </address>
    </div>
  </div>

  <div class="border-t border-gie-navy-light">
    <div class="mx-auto max-w-6xl px-4 py-2 sm:px-6">
      <p class="text-center text-xs text-gray-400">{company.copyright}</p>
    </div>
  </div>
</footer>
