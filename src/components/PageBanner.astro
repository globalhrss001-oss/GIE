---
import { asset } from '../utils/url';

interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;
const imagePath = image.startsWith('/') ? image.slice(1) : image;
---

<section class="relative overflow-hidden bg-gie-navy py-14 text-white">
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <img
      src={asset(imagePath)}
      alt=""
      class="h-full w-full scale-105 object-cover object-center blur-sm"
      aria-hidden="true"
    />
  </div>
  <div class="absolute inset-0 bg-gie-navy/80" aria-hidden="true" />
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <h1 class="text-3xl font-bold sm:text-4xl">{title}</h1>
    <p class="mt-3 max-w-2xl text-gray-200">{description}</p>
    <slot />
  </div>
</section>
