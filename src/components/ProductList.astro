---
import type { Product } from '../data/products';

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2">
  {
    products.map((product, index) => (
      <article
        id={product.id}
        class="group relative scroll-mt-24 overflow-hidden rounded-lg border-l-4 border-gie-navy bg-white p-5 shadow-sm ring-1 ring-gray-100 transition-shadow hover:shadow-md sm:p-6"
      >
        <span
          class="pointer-events-none absolute right-4 top-4 text-4xl font-bold tabular-nums text-gie-navy/10 transition-colors group-hover:text-gie-navy/15"
          aria-hidden="true"
        >
          {String(index + 1).padStart(2, '0')}
        </span>
        <h3 class="relative pr-12 text-lg font-bold text-gie-navy sm:text-xl">{product.name}</h3>
        <p class="relative mt-2 text-sm leading-relaxed text-gie-muted sm:text-base">
          {product.description}
        </p>
      </article>
    ))
  }
</div>
