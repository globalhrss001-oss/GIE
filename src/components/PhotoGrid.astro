---
import { asset } from '../utils/url';

interface Photo {
  src: string;
  alt: string;
  title?: string;
}

interface Props {
  photos: Photo[];
  columns?: 2 | 3 | 4;
}

const { photos, columns = 3 } = Astro.props;

const colClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-3',
}[columns];
---

<div class:list={['grid gap-5', colClass]}>
  {
    photos.map((photo) => (
      <figure class="flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="flex h-72 items-center justify-center bg-gray-50 px-3 sm:h-80">
          <img
            src={asset(photo.src.startsWith('/') ? photo.src.slice(1) : photo.src)}
            alt={photo.alt}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
            width="640"
            height="480"
          />
        </div>
        {
          photo.title && (
            <figcaption class="border-t border-gray-100 px-3 py-3 text-center text-sm font-medium text-gie-navy">
              {photo.title}
            </figcaption>
          )
        }
      </figure>
    ))
  }
</div>
