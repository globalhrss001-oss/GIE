---
import { company } from '../data/company';
import { industriesStrip } from '../data/industries';
import { heroSlides } from '../data/sitePhotos';
import { asset, url } from '../utils/url';
import LogoMark from './LogoMark.astro';

const slideInterval = 5;
const totalDuration = heroSlides.length * slideInterval;
---

<section class="relative overflow-hidden bg-gie-navy text-white">
  <div class="absolute inset-0" aria-hidden="true">
    {
      heroSlides.map((photo, index) => (
        <img
          src={asset(photo.src.replace(/^\//, ''))}
          alt=""
          class="hero-bg-slide absolute inset-0 h-full w-full object-cover"
          style={`animation-delay: ${-index * slideInterval}s`}
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={index === 0 ? 'high' : 'auto'}
        />
      ))
    }
    <div class="absolute inset-0 bg-gie-navy/75"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
    <div class="max-w-3xl">
      <div class="mb-6">
        <LogoMark size="lg" onDark />
      </div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        {company.name}
      </h1>
      <p class="mt-4 text-lg text-gray-200 sm:text-xl">{company.tagline}</p>
      <p class="mt-2 text-sm text-gray-300">
        Est. {company.foundedYear} · Headquarters: {company.headquarters}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={url('/services/')}
          class="rounded-md bg-white px-5 py-2.5 text-sm font-semibold text-gie-navy transition-colors hover:bg-gray-100"
        >
          Our Services
        </a>
        <a
          href={url('/contact/')}
          class="rounded-md border border-white/40 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>

  <div class="relative border-t border-white/10 bg-gie-navy-light/80">
    <p class="mx-auto max-w-6xl px-4 py-3 text-center text-xs font-semibold tracking-wide text-gray-300 uppercase sm:px-6 sm:text-sm">
      {industriesStrip}
    </p>
  </div>
</section>

<style define:vars={{ totalDuration: `${totalDuration}s` }}>
  @keyframes hero-bg-fade {
    0% {
      opacity: 0;
      transform: scale(1);
    }
    3% {
      opacity: 1;
    }
    17% {
      opacity: 1;
      transform: scale(1.06);
    }
    20% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  .hero-bg-slide {
    animation: hero-bg-fade var(--totalDuration) infinite;
    opacity: 0;
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-slide {
      animation: none;
    }

    .hero-bg-slide:first-child {
      opacity: 1;
      transform: none;
    }

    .hero-bg-slide:not(:first-child) {
      display: none;
    }
  }
</style>
