---
import { company } from '../data/company';
import { industriesStrip } from '../data/industries';
import { asset, url } from '../utils/url';
---

<section class="relative overflow-hidden bg-gie-navy text-white">
  <div class="absolute inset-0 opacity-10">
    <img
      src={asset('images/gallery/service-3.jpg')}
      alt=""
      class="h-full w-full object-cover"
      aria-hidden="true"
    />
  </div>
  <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
    <div class="max-w-3xl">
      <img
        src={asset('images/logo/gie-logo.png')}
        alt={company.logoAlt}
        class="mb-6 h-16 w-16 object-contain sm:h-20 sm:w-20"
        width="80"
        height="80"
      />
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        {company.name}
      </h1>
      <p class="mt-4 text-lg text-gray-200 sm:text-xl">{company.tagline}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={url('/services/')}
          class="rounded-md bg-white px-5 py-2.5 text-sm font-semibold text-gie-navy transition-colors hover:bg-gray-100"
        >
          Our Services
        </a>
        <a
          href={url('/contact/')}
          class="rounded-md border border-white/40 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>
  <div class="relative border-t border-white/10 bg-gie-navy-light/80">
    <p class="mx-auto max-w-6xl px-4 py-3 text-center text-xs font-semibold tracking-wide text-gray-300 uppercase sm:px-6 sm:text-sm">
      {industriesStrip}
    </p>
  </div>
</section>
