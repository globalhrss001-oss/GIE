---
import { company } from '../data/company';

const items = [
  {
    label: 'Mission',
    text: company.mission,
  },
  {
    label: 'Vision',
    text: company.vision,
  },
] as const;
---

<section class="mission-vision-root border-y border-gie-navy/10 bg-white py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid md:grid-cols-2">
      {
        items.map((item, index) => (
          <div
            class:list={[
              'mission-vision-reveal flex flex-col items-center px-6 py-2 text-center sm:px-10',
              index === 0 ? 'mission-vision-reveal-left' : 'mission-vision-reveal-right',
              index === 0 && 'md:border-r md:border-gie-navy/15',
              index === 1 && 'mt-12 border-t border-gie-navy/15 pt-12 md:mt-0 md:border-t-0 md:pt-2',
            ]}
            style={`--reveal-delay: ${index * 120}ms`}
          >
            <div class="flex flex-col items-center">
              {
                index === 0 ? (
                  <svg
                    class="mission-vision-icon mission-icon h-16 w-16 text-gie-navy sm:h-20 sm:w-20"
                    viewBox="0 0 64 64"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle
                      class="mission-ring mission-ring-outer"
                      cx="32"
                      cy="32"
                      r="24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    />
                    <circle
                      class="mission-ring mission-ring-mid"
                      cx="32"
                      cy="32"
                      r="16"
                      stroke="currentColor"
                      stroke-width="2.5"
                    />
                    <circle
                      class="mission-ring mission-ring-inner"
                      cx="32"
                      cy="32"
                      r="8"
                      stroke="currentColor"
                      stroke-width="2.5"
                    />
                    <g class="mission-arrow">
                      <path
                        d="M46 18L34 30"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                      />
                      <path
                        d="M46 18L38 20L40 26L46 18Z"
                        fill="currentColor"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linejoin="round"
                      />
                    </g>
                  </svg>
                ) : (
                  <svg
                    class="mission-vision-icon vision-icon h-16 w-16 text-gie-navy sm:h-20 sm:w-20"
                    viewBox="0 0 64 64"
                    fill="none"
                    aria-hidden="true"
                  >
                    <g class="vision-bulb">
                      <path
                        class="vision-bulb-glass"
                        d="M32 10C24 10 18 16.5 18 25.5C18 33 22 38 24 40.5V44C24 45.1 24.9 46 26 46H38C39.1 46 40 45.1 40 44V40.5C42 38 46 33 46 25.5C46 16.5 40 10 32 10Z"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linejoin="round"
                      />
                      <path
                        class="vision-bulb-base"
                        d="M26 46H38V48C38 49.1 37.1 50 36 50H28C26.9 50 26 49.1 26 48V46Z"
                        fill="currentColor"
                      />
                    </g>
                    <path
                      class="vision-bulb-rays"
                      d="M24 52H40"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                    />
                    <path
                      class="vision-bulb-rays"
                      d="M26 56H38"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                    />
                  </svg>
                )
              }

              <p class="mt-4 text-sm font-bold tracking-[0.22em] text-gie-navy uppercase sm:text-base">
                {item.label}
              </p>
            </div>

            <p class="mt-5 max-w-md text-base leading-relaxed text-gie-muted sm:text-lg">
              {item.text}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mission-vision-reveal {
    opacity: 0;
    transform: translate3d(var(--reveal-x, 0), 0, 0);
    transition:
      opacity 0.65s ease,
      transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  .mission-vision-reveal-left {
    --reveal-x: -4rem;
  }

  .mission-vision-reveal-right {
    --reveal-x: 4rem;
  }

  .mission-vision-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .mission-ring,
  .mission-arrow,
  .vision-bulb,
  .vision-bulb-rays {
    transform-box: fill-box;
    transform-origin: center;
  }

  .mission-ring {
    opacity: 0;
    transform: scale(0.55);
  }

  .mission-arrow {
    opacity: 0;
    transform: translate(10px, -10px);
  }

  .vision-bulb {
    opacity: 0;
    transform: scale(0.82) translateY(8px);
    transform-origin: center bottom;
  }

  .vision-bulb-rays {
    opacity: 0;
    transform: scaleX(0.4);
  }

  .mission-vision-reveal.is-visible .mission-ring-outer {
    animation: mission-ring-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.15s;
  }

  .mission-vision-reveal.is-visible .mission-ring-mid {
    animation: mission-ring-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.3s;
  }

  .mission-vision-reveal.is-visible .mission-ring-inner {
    animation:
      mission-ring-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.45s,
      mission-target-pulse 2.8s ease-in-out infinite 1.1s;
  }

  .mission-vision-reveal.is-visible .mission-arrow {
    animation: mission-arrow-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.65s;
  }

  .mission-vision-reveal.is-visible .vision-bulb {
    animation:
      vision-bulb-in 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.2s,
      vision-bulb-glow 3.2s ease-in-out infinite 1.05s;
  }

  .mission-vision-reveal.is-visible .vision-bulb-rays {
    animation: vision-rays-in 0.5s ease forwards 0.75s;
  }

  @keyframes mission-ring-in {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes mission-arrow-in {
    to {
      opacity: 1;
      transform: translate(0, 0);
    }
  }

  @keyframes mission-target-pulse {
    0%,
    100% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.12);
    }
  }

  @keyframes vision-bulb-in {
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes vision-bulb-glow {
    0%,
    100% {
      filter: drop-shadow(0 0 0 rgb(43 58 120 / 0));
    }

    50% {
      filter: drop-shadow(0 0 10px rgb(43 58 120 / 0.35));
    }
  }

  @keyframes vision-rays-in {
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @media (min-width: 768px) {
    .mission-vision-reveal-left {
      --reveal-x: -5rem;
    }

    .mission-vision-reveal-right {
      --reveal-x: 5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mission-vision-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .mission-ring,
    .mission-arrow,
    .vision-bulb,
    .vision-bulb-rays {
      opacity: 1;
      transform: none;
      animation: none !important;
      filter: none;
    }
  }
</style>

<script>
  function initMissionVisionReveal() {
    document.querySelectorAll('.mission-vision-root').forEach((root) => {
      const revealItems = root.querySelectorAll('.mission-vision-reveal');

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        revealItems.forEach((item) => item.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            revealItems.forEach((item) => item.classList.add('is-visible'));
            observer.disconnect();
          });
        },
        {
          threshold: 0.2,
          rootMargin: '0px 0px -5% 0px',
        },
      );

      observer.observe(root);
    });
  }

  initMissionVisionReveal();
</script>
