---
import { company } from '../data/company';

const items = [
  {
    label: 'Mission',
    text: company.mission,
  },
  {
    label: 'Vision',
    text: company.vision,
  },
] as const;
---

<section class="border-y border-gie-navy/10 bg-white py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid md:grid-cols-2">
      {
        items.map((item, index) => (
          <div
            class:list={[
              'flex flex-col items-center px-6 py-2 text-center sm:px-10',
              index === 0 && 'md:border-r md:border-gie-navy/15',
              index === 1 && 'mt-12 border-t border-gie-navy/15 pt-12 md:mt-0 md:border-t-0 md:pt-2',
            ]}
          >
            <div class="flex flex-col items-center">
              {
                index === 0 ? (
                  <svg
                    class="h-16 w-16 text-gie-navy sm:h-20 sm:w-20"
                    viewBox="0 0 64 64"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="2.5" />
                    <circle cx="32" cy="32" r="16" stroke="currentColor" stroke-width="2.5" />
                    <circle cx="32" cy="32" r="8" stroke="currentColor" stroke-width="2.5" />
                    <path
                      d="M46 18L34 30"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                    />
                    <path
                      d="M46 18L38 20L40 26L46 18Z"
                      fill="currentColor"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linejoin="round"
                    />
                  </svg>
                ) : (
                  <svg
                    class="h-16 w-16 text-gie-navy sm:h-20 sm:w-20"
                    viewBox="0 0 64 64"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M32 10C24 10 18 16.5 18 25.5C18 33 22 38 24 40.5V44C24 45.1 24.9 46 26 46H38C39.1 46 40 45.1 40 44V40.5C42 38 46 33 46 25.5C46 16.5 40 10 32 10Z"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M26 46H38V48C38 49.1 37.1 50 36 50H28C26.9 50 26 49.1 26 48V46Z"
                      fill="currentColor"
                    />
                    <path d="M24 52H40" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                    <path d="M26 56H38" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                  </svg>
                )
              }

              <p class="mt-4 text-sm font-bold tracking-[0.22em] text-gie-navy uppercase sm:text-base">
                {item.label}
              </p>
            </div>

            <p class="mt-5 max-w-md text-base leading-relaxed text-gie-muted sm:text-lg">
              {item.text}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
