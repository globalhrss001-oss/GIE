---
import { services } from '../data/services';
---

<!-- TODO: wire Formspree endpoint for real form submission -->
<form id="contact-form" class="space-y-5" novalidate>
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="name" class="mb-1 block text-sm font-medium text-gie-text">Full Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
      />
    </div>
    <div>
      <label for="company" class="mb-1 block text-sm font-medium text-gie-text">Company</label>
      <input
        type="text"
        id="company"
        name="company"
        autocomplete="organization"
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
      />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="country" class="mb-1 block text-sm font-medium text-gie-text">Country *</label>
      <select
        id="country"
        name="country"
        required
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
      >
        <option value="">Select country</option>
        <option value="SG">Singapore</option>
        <option value="MY">Malaysia</option>
        <option value="MM">Myanmar</option>
        <option value="OTHER">Other</option>
      </select>
    </div>
    <div>
      <label for="service" class="mb-1 block text-sm font-medium text-gie-text">Service Interest</label>
      <select
        id="service"
        name="service"
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
      >
        <option value="">Select a service</option>
        {
          services.map((s) => (
            <option value={s.id}>{s.title}</option>
          ))
        }
      </select>
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="email" class="mb-1 block text-sm font-medium text-gie-text">Email *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
      />
    </div>
    <div>
      <label for="phone" class="mb-1 block text-sm font-medium text-gie-text">Phone</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        autocomplete="tel"
        class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
      />
    </div>
  </div>

  <div>
    <label for="message" class="mb-1 block text-sm font-medium text-gie-text">Message *</label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gie-navy focus:ring-1 focus:ring-gie-navy focus:outline-none"
    ></textarea>
  </div>

  <div id="form-success" class="hidden rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800" role="status">
    Thank you. Form submission will be enabled soon.
  </div>

  <button
    type="submit"
    class="rounded-md bg-gie-navy px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gie-navy-light"
  >
    Send Message
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    success?.classList.remove('hidden');
    form.reset();
    success?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
