---
import { certifications } from '../data/certifications';
import { certificatePhoto } from '../data/sitePhotos';
import { asset } from '../utils/url';
---

<div class="space-y-8">
  <figure class="overflow-hidden rounded-xl border border-gray-200 bg-white p-6 shadow-sm sm:p-8">
    <img
      src={asset(certificatePhoto.src.slice(1))}
      alt={certificatePhoto.alt}
      class="mx-auto w-full max-w-5xl object-contain max-h-80 sm:max-h-96 lg:max-h-[28rem]"
      loading="lazy"
      width="1200"
      height="600"
    />
  </figure>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      certifications.map((cert) => (
        <article class="rounded-lg border border-gray-200 bg-white p-5 text-center shadow-sm">
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-gie-navy text-lg font-bold text-white">
            ✓
          </div>
          <h3 class="text-sm font-bold text-gie-navy">{cert.name}</h3>
          <p class="mt-1 text-xs text-gie-muted">{cert.type}</p>
        </article>
      ))
    }
  </div>
</div>
