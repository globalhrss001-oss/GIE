---
import { certifications } from '../data/certifications';
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {
    certifications.map((cert) => (
      <article class="rounded-lg border border-gray-200 bg-white p-5 text-center shadow-sm">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-gie-navy text-lg font-bold text-white">
          ✓
        </div>
        <h3 class="text-sm font-bold text-gie-navy">{cert.name}</h3>
        <p class="mt-1 text-xs text-gie-muted">{cert.type}</p>
      </article>
    ))
  }
</div>
