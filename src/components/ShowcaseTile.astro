---
interface Props {
  href: string;
  label: string;
  index?: number;
  align?: 'center' | 'left';
}

const { href, label, index, align = 'left' } = Astro.props;
const centered = align === 'center';
---

<a
  href={href}
  class:list={[
    'group relative flex h-full min-h-[4.5rem] flex-col overflow-hidden rounded-xl border border-gray-200/80 bg-white p-4 shadow-sm ring-1 ring-gray-100 transition-all duration-200 hover:-translate-y-0.5 hover:border-gie-navy/30 hover:shadow-lg sm:min-h-[5rem] sm:p-5',
    centered ? 'items-center text-center' : 'items-start text-left',
  ]}
>
  {
    index !== undefined && (
      <span
        class="pointer-events-none absolute right-3 top-3 text-xl font-bold tabular-nums text-gie-navy/10 transition-colors group-hover:text-gie-navy/20 sm:right-4 sm:top-4 sm:text-2xl"
        aria-hidden="true"
      >
        {String(index).padStart(2, '0')}
      </span>
    )
  }

  <div
    class:list={[
      'mb-3 h-1 w-10 rounded-full bg-gie-navy transition-all duration-200 group-hover:w-14',
      centered && 'mx-auto',
    ]}
  />

  {
    centered ? (
      <>
        <span class="relative px-1 text-sm font-bold leading-snug text-gie-navy sm:text-base">
          {label}
        </span>
        <span
          class="mt-2 text-xs font-semibold uppercase tracking-wider text-gie-navy-light opacity-0 transition-opacity duration-200 group-hover:opacity-100"
          aria-hidden="true"
        >
          Learn more
        </span>
      </>
    ) : (
      <span
        class:list={[
          'relative flex w-full items-start justify-between gap-3 text-sm font-bold leading-snug text-gie-navy sm:text-base',
          index !== undefined && 'pr-1',
        ]}
      >
        {label}
        <span
          class="mt-0.5 shrink-0 text-gie-navy-light opacity-0 transition-opacity duration-200 group-hover:opacity-100"
          aria-hidden="true"
        >
          →
        </span>
      </span>
    )
  }
</a>
