---
interface Props {
  href: string;
  label: string;
  index?: number;
  align?: 'center' | 'left';
  theme?: 'light' | 'dark';
}

const { href, label, index, align = 'left', theme = 'light' } = Astro.props;
const centered = align === 'center';
const isDark = theme === 'dark';
---

<a
  href={href}
  class:list={[
    'group relative flex h-full min-h-[4.5rem] flex-col overflow-hidden rounded-xl p-4 transition-all duration-200 hover:-translate-y-0.5 sm:min-h-[5rem] sm:p-5',
    isDark
      ? 'border border-white/25 bg-gie-navy/35 shadow-sm backdrop-blur-md hover:border-white/40 hover:bg-gie-navy/45 hover:shadow-lg'
      : 'border border-gray-200/80 bg-white shadow-sm ring-1 ring-gray-100 hover:border-gie-navy/30 hover:shadow-lg',
    centered ? 'items-center text-center' : 'items-start text-left',
  ]}
>
  {
    index !== undefined && (
      <span
        class:list={[
          'pointer-events-none absolute right-3 top-3 text-xl font-bold tabular-nums transition-colors sm:right-4 sm:top-4 sm:text-2xl',
          isDark
            ? 'text-white/15 group-hover:text-white/25'
            : 'text-gie-navy/10 group-hover:text-gie-navy/20',
        ]}
        aria-hidden="true"
      >
        {String(index).padStart(2, '0')}
      </span>
    )
  }

  <div
    class:list={[
      'mb-3 h-1 w-10 rounded-full transition-all duration-200 group-hover:w-14',
      isDark ? 'bg-white/90' : 'bg-gie-navy',
      centered && 'mx-auto',
    ]}
  />

  {
    centered ? (
      <>
        <span
          class:list={[
            'relative px-1 text-sm font-bold leading-snug sm:text-base',
            isDark ? 'text-white' : 'text-gie-navy',
          ]}
        >
          {label}
        </span>
        <span
          class:list={[
            'mt-2 text-xs font-semibold uppercase tracking-wider opacity-0 transition-opacity duration-200 group-hover:opacity-100',
            isDark ? 'text-white/75' : 'text-gie-navy-light',
          ]}
          aria-hidden="true"
        >
          Learn more
        </span>
      </>
    ) : (
      <span
        class:list={[
          'relative flex w-full items-start justify-between gap-3 text-sm font-bold leading-snug sm:text-base',
          isDark ? 'text-white' : 'text-gie-navy',
          index !== undefined && 'pr-1',
        ]}
      >
        {label}
        <span
          class:list={[
            'mt-0.5 shrink-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100',
            isDark ? 'text-white/80' : 'text-gie-navy-light',
          ]}
          aria-hidden="true"
        >
          →
        </span>
      </span>
    )
  }
</a>
