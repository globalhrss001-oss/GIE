---
import { asset } from '../utils/url';
import { teamPhoto } from '../data/sitePhotos';

interface Props {
  reverse?: boolean;
}

const { reverse = false } = Astro.props;
---

<div class:list={['grid items-center gap-8 lg:grid-cols-2', reverse && 'lg:[direction:rtl]']}>
  <div class:list={[reverse && 'lg:[direction:ltr]']}>
    <slot />
  </div>
  <figure class:list={['overflow-hidden rounded-xl border border-gray-200 shadow-md', reverse && 'lg:[direction:ltr]']}>
    <img
      src={asset(teamPhoto.src.slice(1))}
      alt={teamPhoto.alt}
      class="aspect-[4/3] w-full object-cover lg:aspect-auto lg:min-h-[320px]"
      loading="lazy"
      width="800"
      height="600"
    />
    <figcaption class="bg-gie-gray px-4 py-3 text-center text-sm text-gie-muted">
      {teamPhoto.caption}
    </figcaption>
  </figure>
</div>
