---
import { industries, industryShowcasePhotos } from '../data/industries';
import { asset, url } from '../utils/url';
---

<section class="py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-10 text-center">
      <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Industries We Serve</h2>
      <p class="mt-2 text-gie-muted">Supporting critical sectors across Asia and globally.</p>
    </div>

    <div class="grid gap-10 lg:grid-cols-2 lg:items-start lg:gap-12">
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        {
          industryShowcasePhotos.map((photo) => (
            <div class="aspect-square overflow-hidden rounded-lg border border-gray-200 bg-gray-50 shadow-sm">
              <img
                src={asset(photo.src.replace(/^\//, ''))}
                alt={photo.alt}
                class="h-full w-full object-cover"
                loading="lazy"
                width="400"
                height="400"
              />
            </div>
          ))
        }
      </div>

      <ul class="divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white shadow-sm">
        {
          industries.map((industry) => (
            <li class="px-5 py-3.5 sm:px-6 sm:py-4">
              <h3 class="font-bold text-gie-navy">{industry.name}</h3>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-8 text-center">
      <a
        href={url('/industries/')}
        class="inline-block rounded-md bg-gie-navy px-6 py-2.5 text-sm font-semibold text-white hover:bg-gie-navy-light"
      >
        View All Industries
      </a>
    </div>
  </div>
</section>
