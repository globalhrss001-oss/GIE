---
import type { Office } from '../data/offices';

interface Props {
  office: Office;
}

const { office } = Astro.props;
const hasContact = Boolean(office.address || office.phone || office.email || office.mobile);
---

<article class="flex flex-col rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
  <p class="text-xs font-semibold tracking-wider text-gie-navy uppercase">{office.country}</p>
  <h3 class="mt-2 text-base font-bold text-gie-text">{office.entity}</h3>

  {
    office.contactPerson && (
      <p class="mt-3 text-sm text-gie-muted">
        {office.contactPerson}
        {office.title && ` · ${office.title}`}
      </p>
    )
  }

  {
    hasContact ? (
      <address class="mt-4 space-y-1 text-sm not-italic text-gie-text">
        {office.address?.map((line) => <span class="block">{line}</span>)}
        {office.phone && (
          <span class="block pt-2">
            Tel:{' '}
            <a href={`tel:${office.phone.replace(/\s/g, '')}`} class="text-gie-navy hover:underline">
              {office.phone}
            </a>
          </span>
        )}
        {office.fax && <span class="block">Fax: {office.fax}</span>}
        {office.mobile && (
          <span class="block">
            Mobile:{' '}
            <a href={`tel:${office.mobile.replace(/[^\d+]/g, '')}`} class="text-gie-navy hover:underline">
              {office.mobile}
            </a>
          </span>
        )}
        {office.email && (
          <span class="block">
            Email:{' '}
            <a href={`mailto:${office.email}`} class="text-gie-navy hover:underline">{office.email}</a>
          </span>
        )}
        {
          office.workshop && (
            <div class="mt-4 border-t border-gray-100 pt-4">
              <p class="font-semibold text-gie-navy">{office.workshop.name}</p>
              {office.workshop.address.map((line) => (
                <span class="block">{line}</span>
              ))}
              {office.workshop.phone && (
                <span class="block pt-1">
                  Tel:{' '}
                  <a href={`tel:${office.workshop.phone.replace(/[^\d+]/g, '')}`} class="text-gie-navy hover:underline">
                    {office.workshop.phone}
                  </a>
                </span>
              )}
            </div>
          )
        }
      </address>
    ) : (
      <p class="mt-4 text-sm text-gie-muted">Contact details coming soon.</p>
    )
  }
</article>
