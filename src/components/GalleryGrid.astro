---
import type { GalleryImage } from '../data/gallery';
import { asset } from '../utils/url';
import LogoMark from './LogoMark.astro';

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;

function mediaPath(src: string): string {
  return asset(src.startsWith('/') ? src.slice(1) : src);
}
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {
    images.map((image) => (
      <article class="group flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md">
        <div class="relative flex h-64 items-center justify-center bg-gray-50 px-3 sm:h-72">
          {
            image.type === 'video' ? (
              <video
                class="max-h-full max-w-full object-contain"
                controls
                preload="metadata"
                playsinline
                poster={image.poster ? mediaPath(image.poster) : undefined}
                width="640"
                height="480"
              >
                <source src={mediaPath(image.src)} type="video/mp4" />
              </video>
            ) : (
              <img
                src={mediaPath(image.src)}
                alt={image.alt}
                class="max-h-full max-w-full object-contain"
                loading="lazy"
                width="640"
                height="480"
              />
            )
          }
          <span class="absolute top-3 left-3 rounded-full bg-gie-navy px-3 py-1 text-xs font-semibold text-white shadow-sm">
            {image.category}
          </span>
          {
            image.type === 'video' && (
              <span class="absolute top-3 right-3 rounded-full bg-black/60 px-2.5 py-1 text-xs font-semibold text-white">
                Video
              </span>
            )
          }
        </div>
        <div class="flex flex-1 flex-col p-4">
          <h3 class="text-base font-semibold text-gie-navy">{image.title}</h3>
          <p class="mt-1 flex-1 text-sm leading-relaxed text-gie-muted">{image.description}</p>
          <div class="mt-3 flex items-center justify-between border-t border-gray-100 pt-3">
            <span class="text-xs font-medium text-gie-navy">Global Infrastructure Engineering</span>
            <LogoMark size="xs" />
          </div>
        </div>
      </article>
    ))
  }
</div>
