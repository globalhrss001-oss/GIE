---
import { services } from '../data/services';
import { url } from '../utils/url';
import ShowcaseTile from './ShowcaseTile.astro';
---

<ul class="grid gap-3 sm:grid-cols-2 sm:gap-4">
  {
    services.map((service, index) => (
      <li>
        <ShowcaseTile
          href={url(`/services/#${service.id}`)}
          label={service.title}
          index={index + 1}
          align="left"
        />
      </li>
    ))
  }
</ul>

<div class="mt-10 text-center">
  <a
    href={url('/services/')}
    class="inline-flex items-center gap-2 rounded-md bg-gie-navy px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-gie-navy-light hover:shadow-md"
  >
    View All Services
    <span aria-hidden="true">→</span>
  </a>
</div>
