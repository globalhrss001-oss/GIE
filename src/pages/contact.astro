---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import OfficeCard from '../components/OfficeCard.astro';
import PageBanner from '../components/PageBanner.astro';
import { activeOffices } from '../data/offices';
import { company } from '../data/company';

const { primaryContact } = company;
const mobileHref = `tel:${primaryContact.mobile.replace(/[^\d+]/g, '')}`;
---

<BaseLayout
  title="Contact"
  description="Contact Global Infrastructure Engineering in Singapore. Tel (65) 6338 4566, email jc@giesg.com."
>
  <PageBanner
    title="Contact Us"
    description="Reach out to our team for engineering services across Singapore, Malaysia, Myanmar, and beyond."
    image="images/working/working-site-3.jpeg"
  >
    <div class="mt-5 border-t border-white/20 pt-5">
      <p class="text-xs font-semibold tracking-wider text-gray-300 uppercase">Primary contact</p>
      <p class="mt-2 text-sm font-semibold text-white">{primaryContact.name}</p>
      <p class="mt-1 text-sm text-gray-200">
        <a href={`mailto:${primaryContact.email}`} class="hover:text-white hover:underline">
          {primaryContact.email}
        </a>
        <span class="mx-2 text-gray-400" aria-hidden="true">·</span>
        <a href={mobileHref} class="hover:text-white hover:underline">
          {primaryContact.mobile}
        </a>
      </p>
    </div>
  </PageBanner>

  <section class="bg-gie-gray py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Regional Presence</h2>
        <p class="mt-2 text-gie-muted">
          Serving clients in Singapore, Malaysia, Myanmar, and across Asia Pacific.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {activeOffices.map((office) => <OfficeCard office={office} />)}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm sm:p-8">
        <h2 class="mb-6 text-xl font-bold text-gie-navy">Send a Message</h2>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
