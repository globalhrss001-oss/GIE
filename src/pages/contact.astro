---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import OfficeCard from '../components/OfficeCard.astro';
import LogoMark from '../components/LogoMark.astro';
import { activeOffices } from '../data/offices';
---

<BaseLayout
  title="Contact"
  description="Contact Global Infrastructure Engineering in Singapore. Tel 6338 4566, email jc@giesg.com."
>
  <section class="bg-gie-navy py-14 text-white">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-4 px-4 sm:flex-row sm:items-center sm:gap-6 sm:px-6">
      <LogoMark size="lg" onDark />
      <div>
        <h1 class="text-3xl font-bold sm:text-4xl">Contact Us</h1>
        <p class="mt-3 max-w-2xl text-gray-200">
          Reach out to our team for engineering services across Singapore, Malaysia, Myanmar, and
          beyond.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm sm:p-8">
        <h2 class="mb-6 text-xl font-bold text-gie-navy">Send a Message</h2>
        <ContactForm />
      </div>
    </div>
  </section>

  <section class="bg-gie-gray py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Regional Presence</h2>
        <p class="mt-2 text-gie-muted">
          Serving clients in Singapore, Malaysia, Myanmar, and across Asia Pacific.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {activeOffices.map((office) => <OfficeCard office={office} />)}
      </div>
    </div>
  </section>
</BaseLayout>
