---
import BaseLayout from '../layouts/BaseLayout.astro';
import IndustryList from '../components/IndustryList.astro';
import { industries } from '../data/industries';
---

<BaseLayout
  title="Industries"
  description="GIE serves power, oil & gas, offshore, petrochemical, food & beverage, water treatment, pharmaceutical, and more across Asia Pacific."
>
  <section class="bg-gie-navy py-10 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold sm:text-4xl">Industries We Serve</h1>
      <p class="mt-3 max-w-2xl text-gray-200">
        Valve automation and mechanical services for critical sectors across Asia Pacific and
        beyond.
      </p>
      <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-gray-300 sm:text-sm">
        {industries.length} sectors
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <IndustryList industries={industries} />
    </div>
  </section>
</BaseLayout>
