---
import BaseLayout from '../layouts/BaseLayout.astro';
import IndustryCard from '../components/IndustryCard.astro';
import { industries, industriesStrip } from '../data/industries';
---

<BaseLayout
  title="Industries"
  description="GIE serves power, oil & gas, offshore & marine, manufacturing, and process plant industries across Singapore, Malaysia, Myanmar, and globally."
>
  <section class="bg-gie-navy py-14 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold sm:text-4xl">Industries We Serve</h1>
      <p class="mt-3 max-w-2xl text-gray-200">{industriesStrip}</p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {industries.map((industry) => <IndustryCard industry={industry} />)}
      </div>
    </div>
  </section>
</BaseLayout>
