---
import BaseLayout from '../layouts/BaseLayout.astro';
import IndustryCard from '../components/IndustryCard.astro';
import { industries } from '../data/industries';
---

<BaseLayout
  title="Industries"
  description="GIE serves power, oil & gas, offshore, petrochemical, and food industries across Singapore, Myanmar, and globally."
>
  <section class="bg-gie-navy py-10 text-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold sm:text-4xl">Industries We Serve</h1>
      <p class="mt-3 max-w-2xl text-gray-200">
        Valve automation and mechanical services for critical sectors across Asia Pacific and
        beyond.
      </p>
    </div>
  </section>

  <section class="py-12 sm:py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-5 sm:grid-cols-2 lg:gap-6">
        {industries.map((industry) => <IndustryCard industry={industry} />)}
      </div>
    </div>
  </section>
</BaseLayout>
