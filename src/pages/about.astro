---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import CertificationBadges from '../components/CertificationBadges.astro';
import ManufacturerList from '../components/ManufacturerList.astro';
import ClientOverview from '../components/ClientOverview.astro';
import OfficeCard from '../components/OfficeCard.astro';
import TeamSection from '../components/TeamSection.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { company } from '../data/company';
import { activeOffices } from '../data/offices';
import { workingPhotos } from '../data/sitePhotos';
import { asset } from '../utils/url';
---

<BaseLayout
  title="About"
  description="Global Infrastructure Engineering — established 2016 in Singapore. Valve automation, mechanical services, ISO certified, serving Asia Pacific."
>
  <PageBanner
    title="About Us"
    description={company.tagline}
    image="images/working/working-site-2.jpeg"
  >
    <p class="mt-2 text-sm text-gray-300">
      Est. {company.foundedYear} · Headquarters: {company.headquarters}
    </p>
    <a
      href={asset('downloads/gie-company-profile.pdf')}
      download="GIE-Company-Profile.pdf"
      class="mt-6 inline-flex items-center gap-2 rounded-md bg-white px-5 py-2.5 text-sm font-semibold text-gie-navy transition-colors hover:bg-gray-100"
    >
      <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        />
      </svg>
      {company.companyProfileLabel}
    </a>
  </PageBanner>

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <TeamSection>
        {
          company.aboutIntro.map((paragraph, i) => (
            <p class:list={['text-lg leading-relaxed text-gie-text', i > 0 && 'mt-4']}>
              {paragraph}
            </p>
          ))
        }
      </TeamSection>

      <div id="certifications" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold text-gie-navy">Our Certifications</h2>
        <p class="mt-2 text-gie-muted">Quality, safety, and environmental management standards.</p>
        <div class="mt-6">
          <CertificationBadges />
        </div>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gie-navy">Field Operations</h2>
        <p class="mt-2 text-gie-muted">Our engineers and technicians at work across industrial sites.</p>
        <div class="mt-6">
          <PhotoGrid photos={workingPhotos.slice(0, 3)} columns={3} />
        </div>
      </div>

      <div id="manufacturers" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold text-gie-navy">Manufacturer Expertise</h2>
        <p class="mt-2 text-gie-muted">
          Our service personnel have extensive expertise across leading valve and actuator
          manufacturers.
        </p>
        <div class="mt-6">
          <ManufacturerList />
        </div>
      </div>

      <div id="clients" class="mt-16 scroll-mt-24">
        <h2 class="text-2xl font-bold text-gie-navy">Our Client Record</h2>
        <p class="mt-2 text-gie-muted">
          Trusted by leading companies across Singapore, Myanmar, and the Asia Pacific region.
        </p>
        <div class="mt-6">
          <ClientOverview />
        </div>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gie-navy">Regional Offices</h2>
        <p class="mt-2 text-gie-muted">
          Headquarters in Singapore with branch operations in Malaysia and Myanmar.
        </p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {activeOffices.map((office) => <OfficeCard office={office} />)}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
