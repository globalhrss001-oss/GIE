---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoMark from '../components/LogoMark.astro';
import CertificationBadges from '../components/CertificationBadges.astro';
import ManufacturerList from '../components/ManufacturerList.astro';
import ClientList from '../components/ClientList.astro';
import OfficeCard from '../components/OfficeCard.astro';
import { company } from '../data/company';
import { offices } from '../data/offices';
---

<BaseLayout
  title="About"
  description="Global Infrastructure Engineering — established 2016 in Singapore. Valve automation, mechanical services, ISO certified, serving Asia Pacific."
>
  <section class="bg-gie-navy py-14 text-white">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-4 px-4 sm:flex-row sm:items-center sm:gap-6 sm:px-6">
      <LogoMark size="lg" onDark />
      <div>
        <h1 class="text-3xl font-bold sm:text-4xl">About Us</h1>
        <p class="mt-3 max-w-2xl text-gray-200">{company.tagline}</p>
        <p class="mt-2 text-sm text-gray-300">
          Est. {company.foundedYear} · Headquarters: {company.headquarters}
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl">
        {
          company.aboutIntro.map((paragraph) => (
            <p class="mt-4 text-lg leading-relaxed text-gie-text first:mt-0">{paragraph}</p>
          ))
        }
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gie-navy">Our Certifications</h2>
        <p class="mt-2 text-gie-muted">Quality, safety, and environmental management standards.</p>
        <div class="mt-6">
          <CertificationBadges />
        </div>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gie-navy">Manufacturer Expertise</h2>
        <p class="mt-2 text-gie-muted">
          Our service personnel have extensive expertise across leading valve and actuator
          manufacturers.
        </p>
        <div class="mt-6">
          <ManufacturerList />
        </div>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gie-navy">Client References</h2>
        <p class="mt-2 text-gie-muted">
          Trusted by leading companies across Singapore, Myanmar, and the Asia Pacific region.
        </p>
        <div class="mt-6">
          <ClientList />
        </div>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-gie-navy">Regional Offices</h2>
        <p class="mt-2 text-gie-muted">
          Branches in Malaysia, Thailand, and Myanmar with headquarters in Singapore.
        </p>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {offices.map((office) => <OfficeCard office={office} />)}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
