---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceShowcase from '../components/ServiceShowcase.astro';
import IndustryShowcase from '../components/IndustryShowcase.astro';
import { company } from '../data/company';
---

<BaseLayout title={company.name} description={company.description}>
  <Hero />

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-10 md:grid-cols-2 md:gap-12">
        <div>
          <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Our Mission</h2>
          <p class="mt-4 text-base leading-relaxed text-gie-muted sm:text-lg">{company.mission}</p>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Our Vision</h2>
          <p class="mt-4 text-base leading-relaxed text-gie-muted sm:text-lg">{company.vision}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-gradient-to-br from-gie-navy via-gie-navy to-gie-navy-light py-16">
    <div class="pointer-events-none absolute -top-24 right-0 h-64 w-64 rounded-full bg-white/5 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -bottom-16 left-0 h-48 w-48 rounded-full bg-white/5 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/70">What We Do</p>
        <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">Our Services</h2>
        <p class="mt-2 text-white/80">
          Valve automation and mechanical services for valves, actuators, and field instrumentation.
        </p>
        <div class="mx-auto mt-4 h-1 w-14 rounded-full bg-white/90" aria-hidden="true"></div>
      </div>
      <ServiceShowcase theme="dark" />
    </div>
  </section>

  <IndustryShowcase />
</BaseLayout>
