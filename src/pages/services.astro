---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { services } from '../data/services';
import { workingPhotos } from '../data/sitePhotos';
import { url } from '../utils/url';

const actionPhotos = workingPhotos.slice(0, 6);
---

<BaseLayout
  title="Services"
  description="GIE valve automation and mechanical services: motorized valve integration, control and safety valve servicing, actuators, field instrumentation, flange management, training, and 3rd party class testing."
>
  <PageBanner
    title="Our Services"
    description="End-to-end valve automation and mechanical services for critical industrial facilities across Asia Pacific."
    image="images/working/working-site-1.jpeg"
  />

  <section id="our-services" class="scroll-mt-24 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <ServiceGrid services={services} />
    </div>
  </section>

  <section id="service-in-action" class="scroll-mt-24 border-y border-gray-200 bg-white py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Service in Action</h2>
      <p class="mt-2 text-gie-muted">On-site valve servicing, testing, and training by our field teams.</p>
      <div class="mt-8">
        <PhotoGrid photos={actionPhotos} columns={3} />
      </div>
      <div class="mt-8 text-center">
        <a
          href={url('/gallery/')}
          class="inline-block rounded-md border border-gie-navy px-6 py-2.5 text-sm font-semibold text-gie-navy transition-colors hover:bg-gie-navy hover:text-white"
        >
          View Full Gallery
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
