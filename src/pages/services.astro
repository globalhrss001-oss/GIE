---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import { services } from '../data/services';
---

<BaseLayout
  title="Services"
  description="GIE valve automation and mechanical services: motorized valve integration, control and safety valve servicing, actuators, field instrumentation, flange management, training, and 3rd party class testing."
>
  <PageBanner
    title="Our Services"
    description="End-to-end valve automation and mechanical services for critical industrial facilities across Asia Pacific and Middle East."
    image="images/working/working-site-1.jpeg"
  />

  <section id="our-services" class="scroll-mt-24 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <ServiceGrid services={services} />
    </div>
  </section>
</BaseLayout>
