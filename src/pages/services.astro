---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FacilitiesList from '../components/FacilitiesList.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { services } from '../data/services';
import { workingPhotos } from '../data/sitePhotos';
import { asset } from '../utils/url';
---

<BaseLayout
  title="Services"
  description="GIE valve automation and mechanical services: motorized valve integration, control and safety valve servicing, actuators, field instrumentation, flange management, training, and 3rd party class testing."
>
  <section class="relative overflow-hidden bg-gie-navy py-14 text-white">
    <div class="absolute inset-0 opacity-20">
      <img
        src={asset('images/working/working-evt-testing.png')}
        alt=""
        class="h-full w-full object-contain object-center"
        aria-hidden="true"
      />
    </div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold sm:text-4xl">Our Services</h1>
      <p class="mt-3 max-w-2xl text-gray-200">
        End-to-end valve automation and mechanical services for critical industrial facilities
        across Asia Pacific.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="border-y border-gray-200 bg-white py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Service in Action</h2>
      <p class="mt-2 text-gie-muted">On-site valve servicing, testing, and training by our field teams.</p>
      <div class="mt-8">
        <PhotoGrid photos={workingPhotos} columns={4} />
      </div>
    </div>
  </section>

  <section class="bg-gie-gray py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-gie-navy sm:text-3xl">Facilities & Capabilities</h2>
      <p class="mt-2 text-gie-muted">
        Mobile test benches, lapping machines, and on-site commissioning equipment.
      </p>
      <div class="mt-8">
        <FacilitiesList />
      </div>
    </div>
  </section>
</BaseLayout>
