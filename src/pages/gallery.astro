---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import PageBanner from '../components/PageBanner.astro';
import { galleryImages } from '../data/gallery';
---

<BaseLayout
  title="Gallery"
  description="Photos from Global Infrastructure Engineering field services, training, and project work."
>
  <PageBanner
    title="Gallery"
    description="A look at our field services, training, and engineering work across industrial facilities."
    image="images/working/working-training.jpg"
  />

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <GalleryGrid images={galleryImages} />
    </div>
  </section>
</BaseLayout>
